{
  "name": "paperclip-plugin-knok",
  "version": "0.1.0",
  "type": "module",
  "description": "Push desktop notifications via Knok when inbox events occur",
  "homepage": "https://github.com/TomasWard1/paperclip-plugin-knok#readme",
  "bugs": {
    "url": "https://github.com/TomasWard1/paperclip-plugin-knok/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TomasWard1/paperclip-plugin-knok.git"
  },
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "node ./esbuild.config.mjs"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "files": [
    "dist",
    ".paperclip-sdk",
    "esbuild.config.mjs",
    "rollup.config.mjs"
  ],
  "keywords": [
    "paperclip",
    "paperclip-plugin",
    "knok",
    "notifications",
    "desktop-notifications",
    "automation"
  ],
  "author": "Tomas Ward",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "@paperclipai/shared": "file:.paperclip-sdk/paperclipai-shared-0.3.1.tgz"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@paperclipai/shared": "file:.paperclip-sdk/paperclipai-shared-0.3.1.tgz",
    "@paperclipai/plugin-sdk": "file:.paperclip-sdk/paperclipai-plugin-sdk-1.0.0.tgz",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
